# Copy this file to .env and fill in real values.
# .env itself is gitignored — never commit real secrets.

# Where the markdown vault lives. Defaults to ./vault if unset.
# Point this at your Obsidian vault folder if you want to literally
# share the same files between this server and Obsidian.
VAULT_DIR=./vault

# Port for the hosted HTTP server (Render sets this automatically).
PORT=8080

# Shared secret for the hosted server. Set this to any long random string,
# then put the SAME value in Claude's connector custom header as:
#   x-mcp-secret: <this value>
# Leave unset only for local-only testing — never deploy without it.
MCP_SHARED_SECRET=
